<!DOCTYPE html>
<html lang="pt-br">
<head><meta name="google-site-verification" content="z7RxYVYUtU8DiyGwn1iwbqR1rVJ3H2jzTIiaMRl4JEg" />
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Jovens com Propósito</title>

<style>
body {
    font-family: Arial, sans-serif;
    margin: 0;
    background: linear-gradient(120deg, #2c3e50, #4ca1af);
    color: #333;
}

header {
    background: rgba(0,0,0,0.7);
    color: white;
    padding: 20px;
    text-align: center;
}

nav {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    background: #1a252f;
}

nav button {
    background: none;
    border: none;
    color: white;
    padding: 15px;
    cursor: pointer;
}

nav button:hover {
    background: #4ca1af;
}

.section { display: none; padding: 20px; }
.active { display: block; }

.card {
    background: white;
    padding: 20px;
    border-radius: 12px;
    margin: 10px auto;
    max-width: 600px;
}

#chatbox {
    position: fixed;
    bottom: 10px;
    right: 10px;
    width: 300px;
    background: white;
    border-radius: 10px;
}

#chatlogs {
    height: 200px;
    overflow-y: auto;
    padding: 10px;
}

#chatinput {
    display: flex;
}

#chatinput input {
    flex: 1;
    padding: 10px;
}

#chatinput button {
    background: #4ca1af;
    border: none;
    color: white;
    padding: 10px;
}
</style>
</head>

<body>

<header>
<h1>🔥 Jovens com Propósito</h1>
<p>Fortaleça sua fé todos os dias</p>
</header>

<nav>
<button onclick="show('home')">Início</button>
<button onclick="show('oracao')">Oração</button>
<button onclick="show('versiculo')">Versículo</button>
<button onclick="show('louvores')">Louvores</button>
</nav>

<div id="home" class="section active">
<div class="card">
<h2>Bem-vindo 🙌</h2>
<p>Um espaço cristão para jovens crescerem na fé.</p>
</div>
</div>

<div id="oracao" class="section">
<div class="card">
<h2>🙏 Oração</h2>
<p id="oracaoTexto"></p>
<button onclick="novaOracao()">Nova</button>
</div>
</div>

<div id="versiculo" class="section">
<div class="card">
<h2>📖 Versículo</h2>
<p id="versiculoTexto"></p>
<button onclick="novoVersiculo()">Novo</button>
</div>
</div>

<div id="louvores" class="section">
<div class="card">
<h2>🎵 Louvor</h2>
<iframe width="100%" height="200" src="https://www.youtube.com/embed/0nJ0b9s7Q9k" allowfullscreen></iframe>
</div>
</div>

<!-- CHAT -->
<div id="chatbox">
<div id="chatlogs"></div>
<div id="chatinput">
<input id="msg" placeholder="Digite aqui...">
<button onclick="responder()">Enviar</button>
</div>
</div>

<script>
function show(sec) {
    document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
    document.getElementById(sec).classList.add('active');
}

const oracoes = [
"Senhor, guia meu dia 🙏",
"Deus me fortalece hoje ✨",
"Pai, cuida da minha vida ❤️"
];

const versiculos = [
"Filipenses 4:13",
"Salmos 23:1",
"Jeremias 29:11"
];

function novaOracao() {
    document.getElementById('oracaoTexto').innerText =
    oracoes[Math.floor(Math.random()*oracoes.length)];
}

function novoVersiculo() {
    document.getElementById('versiculoTexto').innerText =
    versiculos[Math.floor(Math.random()*versiculos.length)];
}

function responder() {
    let msg = document.getElementById('msg').value.toLowerCase();
    let resposta = "Deus te abençoe 🙏";

    if(msg.includes("triste")) resposta = "Deus está perto de você 💙";
    if(msg.includes("medo")) resposta = "Não temas, Deus está contigo 🙌";
    if(msg.includes("ansiedade")) resposta = "Confia em Deus 🙏";

    let chat = document.getElementById('chatlogs');
    chat.innerHTML += "<p><b>Você:</b> " + msg + "</p>";
    chat.innerHTML += "<p><b>Assistente:</b> " + resposta + "</p>";

    document.getElementById('msg').value = "";
}

novaOracao();
novoVersiculo();
</script>

</body>
</html>
